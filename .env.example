# Credencial privada obtida em Mercado Pago > Suas integrações > Credenciais
MP_ACCESS_TOKEN=APP_USR-COLOQUE_SEU_ACCESS_TOKEN_AQUI

# Use sandbox durante os testes. Apague ou altere para production quando publicar.
MP_ENV=sandbox

# URL pública exata, sem barra no final. Localhost não funciona nas URLs de retorno.
SITE_URL=https://seu-projeto.vercel.app

# Opcional: envie cada atualização de pagamento para Make, Zapier, n8n ou outro webhook.
ORDER_WEBHOOK_URL=
